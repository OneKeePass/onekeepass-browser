{
  "manifest_version": 3,
  "name": "OneKeePass-Browser",
  "description": "__MSG_extensionDescription__",
  "version": "1.2.0",
  "homepage_url": "https://github.com/OneKeePass",
  "default_locale": "en",
  "author": "OneKeePass Team",
  "icons": {
    "16": "icons/onekeepass_16x16.png",
    "48": "icons/onekeepass_48x48.png",
    "64": "icons/onekeepass_64x64.png",
    "96": "icons/onekeepass_96x96.png",
    "128": "icons/onekeepass_128x128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "onekeepass@gmail.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "page": "background.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/onekeepass_16x16.png",
      "18": "icons/onekeepass_18x18.png",
      "19": "icons/onekeepass_19x19.png",
      "32": "icons/onekeepass_32x32.png",
      "36": "icons/onekeepass_36x36.png",
      "38": "icons/onekeepass_38x38.png",
      "64": "icons/onekeepass_64x64.png"
    },
    "default_title": "OneKeePass"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "passkey-intercept-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "content_main.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "scripting",
    "activeTab",
    "contextMenus",
    "clipboardWrite",
    "nativeMessaging",
    "notifications",
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "js/shared.js",
        "js/cljs-runtime/*",
        "js/content.js",
        "js/entry-list-popup.js",
        "js/message-popup.js",
        "js/passkey-create-popup.js",
        "js/settings-popup.js",
        "entry_list_popup.html",
        "main_popup.html",
        "msg_popup.html",
        "passkey_create_popup.html",
        "settings_popup.html"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}